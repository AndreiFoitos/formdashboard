{
  "expo": {
    "name": "protocol-native",
    "slug": "protocol-native",
    "version": "1.0.0",
    "scheme": "protocol",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asky12346272.protocolnative",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.asky12346272.protocolnative"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.471688772354-9rte1ombjd7p7enmli9b0btcjb5k3v5e"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Protocol uses the camera to identify your meal and estimate calories.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9035cc7e-cb5e-403b-ae10-274b0bd7f8e1"
      },
      "features": {
        "appleSignIn": false,
        "googleSignIn": false
      },
      "googleSignIn": {
        "iosClientId": "471688772354-9rte1ombjd7p7enmli9b0btcjb5k3v5e.apps.googleusercontent.com",
        "webClientId": "471688772354-c9q0begitcjad2eql335mm3jtt2ao4ft.apps.googleusercontent.com"
      }
    }
  }
}

              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.gainrace.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.471688772354-9rte1ombjd7p7enmli9b0btcjb5k3v5e"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Gainrace uses the camera to identify your meal and estimate calories.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0b62e8"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "features": {
        "appleSignIn": true,
        "googleSignIn": true
      },
      "googleSignIn": {
        "iosClientId": "471688772354-9rte1ombjd7p7enmli9b0btcjb5k3v5e.apps.googleusercontent.com",
        "webClientId": "471688772354-c9q0begitcjad2eql335mm3jtt2ao4ft.apps.googleusercontent.com"
      },
      "eas": {
        "projectId": "aaa7b0b7-4c10-49e7-8c1d-2c647097a3f5"
      }
    },
    "owner": "asky12346272"
  }
